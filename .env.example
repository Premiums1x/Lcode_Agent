# LCode 环境配置
# Copy this file to .env and fill in your API keys

# OpenAI格式 API 
OPENAI_API_KEY=${OPENAI_API_KEY} //请将API KEY设置在环境变量中避免泄露
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek API (optional, uses OpenAI-compatible format)
DEEPSEEK_API_KEY=${DEEPSEEK_API_KEY}
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Default Model
DEFAULT_MODEL=gpt-4o-mini
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=4096

# Framework Settings
DEBUG=false
LOG_LEVEL=INFO

# Memory & RAG
MEMORY_TYPE=sqlite
MEMORY_DB_PATH=./data/lcode_memory.db
VECTOR_DB_PATH=./data/vector_db
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=5

# Web UI
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_RELOAD=false

# Multi-Agent
MAX_AGENTS=10
AGENT_TIMEOUT=120

# MCP
MCP_ENABLED=true
MCP_SERVER_PORT=8080

# Plugin
PLUGIN_DIR=./plugins
AUTO_DISCOVER_PLUGINS=true
